{
  "name": "topey",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run mobile:start",
    "test": "npm run mobile:test",
    "mobile:start": "npm run start --workspace @topey/mobile",
    "mobile:android": "npm run android --workspace @topey/mobile",
    "mobile:ios": "npm run ios --workspace @topey/mobile",
    "mobile:web": "npm run web --workspace @topey/mobile",
    "mobile:test": "npm run test --workspace @topey/mobile",
    "mobile:doctor": "npm run doctor --workspace @topey/mobile",
    "web:dev": "npm run dev --workspace @topey/web",
    "web:build": "npm run build --workspace @topey/web",
    "web:preview": "npm run preview --workspace @topey/web",
    "supabase:auth": "node scripts/sync-supabase-auth-config.mjs",
    "supabase:migrate": "node scripts/apply-supabase-sql.mjs supabase/migrations/20260322114500_init_topey.sql",
    "supabase:seed": "node scripts/apply-supabase-sql.mjs supabase/seed.sql",
    "supabase:test-user": "node scripts/create-test-user.mjs"
  }
}
