{
  "name": "topey",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run mobile:start --",
    "test": "npm run mobile:test",
    "mobile:start": "npm --prefix apps/mobile run start --",
    "mobile:android": "npm --prefix apps/mobile run android --",
    "mobile:ios": "npm --prefix apps/mobile run ios --",
    "mobile:web": "npm --prefix apps/mobile run web --",
    "mobile:test": "npm --prefix apps/mobile run test",
    "mobile:doctor": "npm --prefix apps/mobile run doctor",
    "web:dev": "npm --prefix apps/web run dev --",
    "web:build": "npm --prefix apps/web run build --",
    "web:preview": "npm --prefix apps/web run preview --",
    "web:test": "npm --prefix apps/web run test --",
    "supabase:auth": "node scripts/sync-supabase-auth-config.mjs",
    "supabase:migrate": "node scripts/apply-supabase-sql.mjs supabase/migrations/20260322114500_init_topey.sql",
    "supabase:seed": "node scripts/apply-supabase-sql.mjs supabase/seed.sql",
    "supabase:test-user": "node scripts/create-test-user.mjs"
  }
}
